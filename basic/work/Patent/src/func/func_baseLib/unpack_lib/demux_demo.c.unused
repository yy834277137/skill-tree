        }
        if(ret)
        {
            TIME_MS(runTimestamp);
            SAL_ERROR("audpcmout multi_aud err! %x datalen %d runTimestamp %llu\n",ret,demBuf.datalen,runTimestamp);
        }
        */
    }   
    
    return SAL_SOK;
}


